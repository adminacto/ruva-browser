# Maintainer: Ruva Team
pkgname=ruva-browser
pkgver=0.1.0
pkgrel=1
pkgdesc='Ruva Browser — веб-браузер на Rust + GTK + WebKitGTK с AI ассистентом'
arch=('x86_64')
url='https://github.com/anonymus/ruva-browser'
license=('MIT')
depends=('gtk3' 'webkit2gtk-4.1' 'curl')
makedepends=('cargo' 'rust')
source=("$pkgname-$pkgver.tar.gz")
sha256sums=('SKIP')

prepare() {
  cd "$pkgname/native"
  export RUSTUP_TOOLCHAIN=stable
  cargo fetch --locked --target "$(rust-cv -vV | grep host | cut -d' ' -f2)" 2>/dev/null || true
}

build() {
  cd "$pkgname/native"
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR=target
  cargo build --release --frozen
  strip target/release/ruva-browser
}

package() {
  cd "$pkgname/native"
  install -Dm755 target/release/ruva-browser "$pkgdir/usr/bin/ruva-browser"

  install -Dm644 "$srcdir/$pkgname/ui/ntp.html" "$pkgdir/usr/share/ruva-browser/ntp.html"
  install -Dm644 "$srcdir/$pkgname/ui/settings.html" "$pkgdir/usr/share/ruva-browser/settings.html"
  install -Dm644 "$srcdir/$pkgname/ui/setup.html" "$pkgdir/usr/share/ruva-browser/setup.html"

  mkdir -p "$pkgdir/usr/share/applications"
  cat > "$pkgdir/usr/share/applications/ruva-browser.desktop" << EOF
[Desktop Entry]
Name=Ruva Browser
Comment=Веб-браузер с AI ассистентом
Exec=ruva-browser
Icon=ruva-browser
Type=Application
Categories=Network;WebBrowser;
StartupWMClass=ruva-browser
EOF

  mkdir -p "$pkgdir/usr/share/icons/hicolor/256x256/apps"
}
